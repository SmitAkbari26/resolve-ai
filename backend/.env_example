# ─── Resolve AI Environment Configuration ───────────────

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# LLM Provider: openai | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Embeddings: sentence_transformers | openai
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=resolve_ai
POSTGRES_PASSWORD=resolve_ai_pass
POSTGRES_DB=resolve_ai

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=resolve_ai_kb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=resolve_ai_graph

# Workflow
APPROVAL_REFUND_THRESHOLD=100.0
MAX_AUTO_RESOLVE_SEVERITY=medium

# Notifications
SMTP_HOST=localhost
SMTP_PORT=1025
SLACK_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:8501

# MCP
MCP_SERVER_BASE_URL=http://localhost:9000